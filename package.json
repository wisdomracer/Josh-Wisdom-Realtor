{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.mjs",
    "build": "corepack pnpm run typecheck && corepack pnpm -r --filter @workspace/propflow --filter @workspace/api-server --if-present run build",
    "audit:site": "corepack pnpm --filter @workspace/propflow build && playwright test",
    "test:e2e": "playwright test tests/site.spec.ts tests/lead-form.spec.ts",
    "test:a11y": "playwright test tests/accessibility.spec.ts",
    "typecheck:libs": "tsc --build",
    "typecheck": "corepack pnpm run typecheck:libs && corepack pnpm -r --filter @workspace/propflow --filter @workspace/api-server --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "pnpm": {
    "overrides": {
      "router>path-to-regexp": "8.4.2",
      "micromatch>picomatch": "2.3.2",
      "qs": "6.15.2"
    }
  }
}
